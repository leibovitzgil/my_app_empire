{
  "name": "duet-functions",
  "description": "Duet Cloud Functions (TypeScript, firebase-functions v2). Outside melos: npm is the toolchain here.",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
