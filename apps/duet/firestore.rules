rules_version = '2';

// Duet's Firestore security rules. Two groups of collections:
//
//  1. Identity/discovery (live since M1): `usersByEmail` (email directory),
//     `deviceTokens` (push-token registry), `userInbox` (the generic message
//     inbox invites ride over). Backed by client contracts in
//     `core/user_directory` / `services/notifications`.
//
//  2. Pieces + annotations (M2.2): `pieces` and its `layers`/`notes`/`reads`
//     subcollections. These rules are the enforced translation of
//     `docs/duet_cloud_schema.md` and mirror the ownership guards the local
//     repositories enforce client-side today
//     (`LocalPieceRepository.deletePiece` = owner-only;
//     `LocalAnnotationRepository` = author-only stroke/note mutation). They
//     supersede the old commented `teacherId`/`collaboratorIds` sketch.
//     **No client writes these yet** — piece/annotation storage is still
//     on-device (`local_storage`); the rules land first and are proven by
//     the M2.3 test suite *before* the M3/M4 sync code that will write them
//     (G6). `inviteTokens` (M5.2) is explicitly Function-only below;
//     `entitlements` (M6.3) stays denied-by-default until its milestone.
//
// Discovery is server-only (M2.5): a client may read only its *own*
// `usersByEmail` entry — resolving someone else's email now goes through the
// rate-limited `lookupEmail` Cloud Function (Admin SDK), which honors
// `discoverable` and bounds enumeration/brute-force per caller. `list`/`query`
// is never allowed. This closed the v1 un-rate-limited-lookup vector.
//
// `userInbox` writes are server-only (M2.4): a client can read and mark its
// own messages read, but can no longer `create` one — the `sendInvite` Cloud
// Function (Admin SDK) is the sole writer, and only to a resolved, discoverable
// recipient. This closed the v1 inbox-spam vector.
service cloud.firestore {
  match /databases/{database}/documents {
    match /usersByEmail/{emailKey} {
      // Self-read only — cross-user discovery is the `lookupEmail` callable's
      // job (see the header note). Never a list/query.
      allow get: if request.auth != null &&
        resource.data.uid == request.auth.uid;
      allow list: if false;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.uid;
      // Update additionally requires owning the EXISTING doc: without the
      // `resource.data.uid` check a signed-in stranger could re-point an
      // email's mapping at their own uid (invite hijack) — found by the
      // M1.7 rules-test harness.
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.uid &&
        request.auth.uid == request.resource.data.uid;
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.uid;
    }

    // Forward-provisioning only (see `FirestoreUserMessaging`'s doc): a
    // signed-in device may only manage its own token list.
    match /deviceTokens/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Each user's own inbox: only its owner may read a message or mark it
    // read. Clients may NOT create a message — that's the `sendInvite` Cloud
    // Function's job (Admin SDK, M2.4), which is what closed the inbox-spam
    // vector. Nothing ever deletes an inbox message outright (see `markRead`).
    match /userInbox/{uid}/messages/{messageId} {
      allow read, update: if request.auth != null && request.auth.uid == uid;
      allow create: if false;
      allow delete: if false;
    }

    // --- Pieces + annotations (M2.2), per docs/duet_cloud_schema.md. --------
    match /pieces/{pieceId} {
      // A participant = the owner or a collaborator; `participantIds` is the
      // materialized [ownerId, ...collaborator uids] the schema defines.
      function isSignedIn() { return request.auth != null; }
      function isParticipant() {
        return isSignedIn() &&
          request.auth.uid in resource.data.participantIds;
      }
      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }

      // Read (get + list) is participant-only. A query must therefore be
      // scoped to the caller's own pieces — e.g.
      // `where('participantIds', arrayContains: myUid)` — or it resolves
      // documents the caller can't read and fails, which is the intent.
      allow read: if isParticipant();

      // Create: the caller is the owner, is the *sole* participant, and
      // brings no collaborators — collaborator membership is only ever added
      // by the invite-accept Function (M2.4), never at create time.
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.ownerId &&
        request.resource.data.participantIds == [request.auth.uid] &&
        request.resource.data.collaborators.size() == 0;

      // Update: the owner may edit metadata only. The membership fields
      // (`participantIds`, `collaborators`) and `ownerId` are immutable to
      // clients — collaborator add/remove is a Cloud Function (M2.4), which
      // uses the Admin SDK and bypasses these rules. This is what makes the
      // per-piece cap (CollaboratorLimits, which depends on monetization
      // state rules can't read) unforgeable from a client.
      allow update: if isOwner() &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.participantIds == resource.data.participantIds &&
        request.resource.data.collaborators == resource.data.collaborators;

      // Delete: owner-only (mirrors LocalPieceRepository's OwnershipViolation
      // on a non-owner deletePiece). Subcollection cleanup cascades via the
      // purge Function, not client deletes.
      allow delete: if isOwner();

      // Resolving the parent piece for a subcollection rule costs one extra
      // document read per request — the price of membership-gating children
      // by the parent's `participantIds`.
      function parentPiece() {
        return get(/databases/$(database)/documents/pieces/$(pieceId)).data;
      }
      function isPieceParticipant() {
        return isSignedIn() && request.auth.uid in parentPiece().participantIds;
      }

      // One layer document per author (id == the author's uid). Conflict-free
      // by construction: a participant may write only *their own* layer.
      match /layers/{uid} {
        allow read: if isPieceParticipant();
        allow create, update: if isSignedIn() &&
          request.auth.uid == uid &&
          isPieceParticipant();
        // The author may delete their own layer; the owner may delete any
        // layer, so removing a collaborator can cascade their ink away.
        allow delete: if isSignedIn() &&
          (request.auth.uid == uid ||
            request.auth.uid == parentPiece().ownerId);
      }

      // One document per audio note. Only the author may create it, and the
      // only permitted update is flipping the `deletedAt` tombstone (M4.4) —
      // notes are never hard-deleted, so a delete converges across offline
      // peers instead of resurrecting.
      match /notes/{noteId} {
        allow read: if isPieceParticipant();
        allow create: if isPieceParticipant() &&
          request.resource.data.authorId == request.auth.uid;
        allow update: if isSignedIn() &&
          resource.data.authorId == request.auth.uid &&
          request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['deletedAt']);
        allow delete: if false;
      }

      // Each participant's own unread watermark (id == their uid). The
      // mirrored `uid` field lets the collection-group read below gather a
      // user's watermarks across pieces; direct get/write stay scoped here.
      match /reads/{uid} {
        allow read, write: if isSignedIn() &&
          request.auth.uid == uid &&
          isPieceParticipant();
      }
    }

    // Collection-group read of a user's own unread watermarks across every
    // piece (M3.7) — the library gathers them in one query. Scoped to the
    // caller's own docs by the mirrored `uid` field, which the query filters
    // on; writes still go through the per-piece `reads/{uid}` rule above.
    match /{path=**}/reads/{readUid} {
      // `isSignedIn()` is scoped to the pieces block above, so inline the
      // signed-in guard here (a null auth can't match `resource.data.uid`).
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.uid;
    }

    // Tokenized deep-link invites (M5.2): entirely Function-owned. A client
    // never reads or writes a token doc — minting is the `createInviteToken`
    // callable (owner + cap checked server-side), the accept screen's
    // preview is `resolveInviteToken`, and redemption is `acceptInviteToken`
    // (sets `consumed`/`consumedBy` transactionally, Admin SDK). The doc id
    // is an unguessable token, but unguessability is not an ACL — deny all,
    // and never a list/query (which would enumerate live tokens).
    match /inviteTokens/{token} {
      allow read, write: if false;
    }

    // Deny-by-default: any path not explicitly matched above (this is what
    // keeps `entitlements` closed until M6.3).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
