# Dart / Flutter
.dart_tool/
.packages
.pub-cache/
.pub/
build/
# Flutter golden-test failure artifacts (regenerated on each failing run)
**/test/golden/failures/
.flutter-plugins
.flutter-plugins-dependencies
pubspec_overrides.yaml

# Melos
.melos_tool/

# Coverage
coverage/
*.lcov

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store

# App-level lockfiles are committed for reproducibility; package lockfiles are not.
packages/**/pubspec.lock

# Firebase emulator runtime logs
*-debug.log
firebase-export-*/
.firebase/

# Duet Cloud Functions workspace (npm — outside melos): dependencies and
# the tsc build output the emulator serves.
apps/duet/functions/node_modules/
apps/duet/functions/lib/

# Duet Firestore rules-test harness (npm — outside melos).
apps/duet/firestore_tests/node_modules/

# Duet local dev (apps/duet/dev.sh): generated, regenerable platform
# scaffolding (the factory commits no platform dirs).
apps/duet/web/
apps/duet/android/
apps/duet/ios/
apps/duet/macos/
apps/duet/linux/
apps/duet/windows/
# Scaffold metadata `flutter create` regenerates alongside the platform dirs.
apps/duet/.metadata
apps/duet/.gitignore
.claude/worktrees/
